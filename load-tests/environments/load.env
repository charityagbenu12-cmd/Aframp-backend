# Load Testing Environment Configuration
# This file contains environment variables for the dedicated load testing environment
# DO NOT commit this file - it contains sensitive information

# Base URL for the load testing environment
# This should point to your isolated load testing environment
BASE_URL=https://api-load-test.aframp.com

# API Key for load testing (dedicated key for load testing only)
LOAD_TEST_API_KEY=your-load-test-api-key-here

# Wallet and transaction fixtures for non-production test data
# These should be test wallets that don't contain real funds
TEST_WALLET_ADDRESS=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAWHF
TEST_TX_ID=tx-load-test-placeholder

# k6 configuration options
K6_INSECURE_SKIP_TLS_VERIFY=false
K6_NO_CONNECTION_REUSE=false

# Load testing environment credentials
# These should be different from production credentials
LOAD_TEST_DB_HOST=load-test-db.aframp.com
LOAD_TEST_DB_PORT=5432
LOAD_TEST_DB_NAME=aframp_load_test
LOAD_TEST_DB_USER=load_test_user
LOAD_TEST_DB_PASSWORD=load_test_password

# Redis configuration for load testing
LOAD_TEST_REDIS_HOST=load-test-redis.aframp.com
LOAD_TEST_REDIS_PORT=6379
LOAD_TEST_REDIS_PASSWORD=load_test_redis_password

# Stellar network configuration for load testing
LOAD_TEST_STELLAR_NETWORK=testnet
LOAD_TEST_STELLAR_HORIZON=https://horizon-testnet.stellar.org
LOAD_TEST_STELLAR_ISSUER=GTESTISSUERXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# External service configurations (mock or test endpoints)
LOAD_TEST_EXTERNAL_RATE_API_URL=https://api-test.aframp.com/rates
LOAD_TEST_EXTERNAL_RATE_API_KEY=test-api-key

# Bill payment provider test credentials
LOAD_TEST_BILL_PROVIDER_API_KEY=test-bill-provider-key
LOAD_TEST_BILL_PROVIDER_SECRET=test-bill-provider-secret

# Monitoring and alerting
LOAD_TEST_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
LOAD_TEST_EMAIL_ALERTS=admin@load-test.aframp.com

# Performance thresholds (can override defaults)
LOAD_TEST_P95_THRESHOLD_MS=500
LOAD_TEST_ERROR_RATE_THRESHOLD=0.02
LOAD_TEST_THROUGHPUT_THRESHOLD_RPS=1000